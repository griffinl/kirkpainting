---
import { formatDate, articleHeadline, kirkScore, isGuide, readingTime } from '../lib/content';
import type { Article } from '../lib/types';

interface Props {
  article: Article;
  featured?: boolean;
  horizontal?: boolean;  // hero layout: side-by-side image + text
}

const { article, featured = false, horizontal = false } = Astro.props;
const url = `/${article.category}/${article.slug}/`;
const headline = articleHeadline(article);
const guide = isGuide(article);

// Top Kirk Score in this roundup — the card's data hook (reviews only).
const topScore = !guide && article.products.length
  ? Math.max(...article.products.map((p) => kirkScore(p)))
  : 0;
---
<article class:list={['article-card', { featured, horizontal }]}>
  {article.featuredImage && (
    <a href={url} class:list={['card-media', { 'is-review': !guide }]} tabindex="-1" aria-hidden="true">
      <img src={article.featuredImage} alt="" loading="lazy" decoding="async" width="600" height="338" />
    </a>
  )}
  <div class="card-body">
    <div class="card-top">
      <a href={`/${article.category}/`} class="card-category badge">
        {article.categoryLabel}
      </a>
      {guide ? (
        <span class="card-tag">Guide</span>
      ) : topScore > 0 && (
        <span class="card-score" title="Top Kirk Score in this guide">
          <span class="kscore"><span class="kscore-num">{topScore}</span><span class="kscore-max">/100</span></span>
        </span>
      )}
    </div>

    <h2 class="card-title">
      <a href={url}>{headline}</a>
    </h2>

    <p class="card-excerpt">{article.excerpt}</p>

    <div class="card-meta">
      <span>{formatDate(article.updatedAt)}</span>
      <span aria-hidden="true">·</span>
      <span>{guide ? `${readingTime(article)} min read` : `${article.products.length} picks scored`}</span>
    </div>
  </div>
</article>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
  }

  .article-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    border-color: var(--color-accent);
  }

  /* Card image — guides show a full-bleed photo (cover), reviews show the
     product shot cleanly (contain on a light panel). */
  .card-media {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-border);
  }

  .card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  /* Amazon product shots are on white — match it so they blend seamlessly. */
  .card-media.is-review {
    background: #fff;
  }

  .card-media.is-review img {
    object-fit: contain;
    padding: 0.75rem;
  }

  .article-card:hover .card-media img { transform: scale(1.03); }

  .card-body {
    padding: 1.25rem 1.5rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    flex: 1;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-category {
    text-decoration: none !important;
  }

  .card-score {
    flex-shrink: 0;
  }

  .card-score .kscore .kscore-num { font-size: 1rem; }

  .card-tag {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-cta);
    border: 1px solid var(--color-cta);
    border-radius: var(--radius-sm);
    padding: 0.15em 0.5em;
    line-height: 1.4;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }

  .card-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .card-title a:hover {
    color: var(--color-accent-ink);
    text-decoration: none;
  }

  .card-excerpt {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  .card-meta {
    display: flex;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    margin-top: auto;
    padding-top: 0.5rem;
  }

  /* Featured card: larger title + accent rail */
  .article-card.featured {
    border-left: 3px solid var(--color-accent);
  }

  .article-card.featured .card-title {
    font-size: 1.4rem;
  }

  .article-card.featured .card-excerpt {
    -webkit-line-clamp: 4;
    font-size: 0.92rem;
  }

  /* Featured card goes side-by-side on desktop so the image stays compact
     (full-width it was enormous). Image left, text right. */
  @media (min-width: 720px) {
    .article-card.featured {
      flex-direction: row;
      align-items: stretch;
    }
    .article-card.featured .card-media {
      width: 38%;
      flex-shrink: 0;
      aspect-ratio: auto;
      border-bottom: none;
      border-right: 1px solid var(--color-border);
    }
    .article-card.featured .card-body {
      flex: 1;
      justify-content: center;
    }
  }

  /* Horizontal variant (hero layout) */
  .article-card.horizontal .card-body {
    flex: 1;
    padding: 1.25rem 1.5rem;
  }

  .article-card.horizontal .card-excerpt {
    -webkit-line-clamp: 2;
  }
</style>
