---
import { kirkScore } from '../lib/content';
import type { Product } from '../lib/types';

interface Props {
  products: Product[];
}

const { products } = Astro.props;
const top = products.slice(0, Math.min(products.length, 5));

const rankBadge = (rank: number) => {
  const defaults: Record<number, string> = {
    1: 'Best Overall',
    2: 'Runner Up',
    3: 'Best Value',
    4: 'Also Great',
    5: 'Also Great',
  };
  return defaults[rank] ?? `#${rank} Pick`;
};
---
<aside class="top-picks" aria-label="Quick picks">
  <div class="tp-head">
    <h2 class="tp-title"><span class="slash">//</span> top picks</h2>
    <span class="tp-meta">ranked by Kirk Score</span>
  </div>

  <ol class="picks-list" role="list">
    {top.map((p) => {
      const score = kirkScore(p);
      return (
      <li class="pick-row">
        <span class="pick-rank">#{String(p.rank).padStart(2, '0')}</span>

        <a href={p.affiliateUrl} target="_blank" rel="sponsored nofollow noopener" class="pick-img">
          <img src={p.image} alt={p.label} loading="lazy" decoding="async" width="56" height="56" />
        </a>

        <div class="pick-info">
          <span class="pick-badge">{p.badge ?? p.bestFor ?? rankBadge(p.rank)}</span>
          <a href={`#product-${p.rank}`} class="pick-name">{p.label}</a>
        </div>

        <div class="pick-score" aria-label={`Kirk Score ${score} out of 100`}>
          <span class="kscore"><span class="kscore-num">{score}</span><span class="kscore-max">/100</span></span>
          <div class="score-bar"><span style={`width:${score}%`}></span></div>
        </div>

        <a
          href={p.affiliateUrl}
          target="_blank"
          rel="sponsored nofollow noopener"
          class="btn btn-primary pick-cta"
        >Check Price</a>
      </li>
      );
    })}
  </ol>
</aside>

<style>
  .top-picks {
    margin: 2rem 0 2.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: #fff;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .tp-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1.25rem;
    background: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-border);
  }

  .tp-title {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
  }

  .tp-title .slash { color: var(--color-accent-ink); }

  .tp-meta {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-text-muted);
  }

  .picks-list { list-style: none; }

  .pick-row {
    display: grid;
    grid-template-columns: 2.4rem 56px 1fr 130px auto;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .pick-row:last-child { border-bottom: none; }

  .pick-rank {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .pick-img {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pick-img img {
    width: 56px;
    height: 56px;
    max-width: 56px !important;
    object-fit: contain;
  }

  .pick-info { min-width: 0; }

  .pick-badge {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-accent-ink);
    margin-bottom: 0.15rem;
  }

  .pick-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .pick-name:hover { color: var(--color-accent-ink); text-decoration: none; }

  .pick-score {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .pick-cta {
    padding: 0.55em 1.1em;
    font-size: 0.82rem;
    white-space: nowrap;
  }

  @media (max-width: 680px) {
    .pick-row {
      grid-template-columns: 1.8rem 48px 1fr;
      grid-template-areas:
        "rank img info"
        "rank score score"
        "rank cta cta";
      row-gap: 0.6rem;
      column-gap: 0.75rem;
    }
    .pick-rank { grid-area: rank; align-self: start; }
    .pick-img { grid-area: img; width: 48px; height: 48px; }
    .pick-img img { width: 48px; height: 48px; max-width: 48px !important; }
    .pick-info { grid-area: info; }
    .pick-score { grid-area: score; }
    .pick-cta { grid-area: cta; justify-self: start; }
  }
</style>
