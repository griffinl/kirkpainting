---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../../site.config';
---
<BaseLayout title="404 — Page Not Found" noindex={true}>
  <section class="nf">
    <div class="container nf-inner">
      <p class="nf-code">// ERROR 404</p>
      <h1 class="nf-title">This page didn't pass inspection.</h1>
      <p class="nf-sub">
        The page you're looking for moved, got repainted, or never existed.
        Let's get you back to gear that actually scores.
      </p>
      <div class="nf-actions">
        <a href="/" class="btn btn-primary">Back to Home</a>
        <a href="/paint-sprayers/" class="btn btn-outline">Browse Reviews</a>
      </div>
      <nav class="nf-cats" aria-label="Popular categories">
        {siteConfig.nav.map((item) => (
          <a href={item.href} class="nf-pill">{item.label}</a>
        ))}
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    background: var(--color-bg-subtle);
    background-image: var(--blueprint-grid);
    background-size: 28px 28px;
    border-bottom: 1px solid var(--color-border);
    padding: 5rem 0;
  }
  .nf-inner { max-width: 640px; }
  .nf-code {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    color: var(--color-accent-ink);
    margin-bottom: 1rem;
  }
  .nf-title {
    font-size: clamp(1.9rem, 5vw, 2.8rem);
    color: var(--color-primary);
    margin-bottom: 1rem;
    letter-spacing: -0.025em;
  }
  .nf-sub {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin-bottom: 1.75rem;
    max-width: 480px;
  }
  .nf-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 2rem; }
  .nf-cats { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .nf-pill {
    padding: 0.35em 0.9em;
    border: 1px solid var(--color-border);
    border-radius: 2em;
    font-size: 0.82rem;
    background: #fff;
    color: var(--color-text);
    text-decoration: none;
  }
  .nf-pill:hover { border-color: var(--color-accent); text-decoration: none; }
</style>
