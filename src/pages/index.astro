---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getAllArticles, isGuide } from '../lib/content';
import { siteConfig } from '../../site.config';

const articles = getAllArticles();

// Reviews and guides are different content — keep them in separate sections.
const reviews = articles.filter((a) => !isGuide(a));
const guideArticles = articles.filter(isGuide);

const featured = reviews[0];
const LATEST_COUNT = 12;
const rest = reviews.slice(1, 1 + LATEST_COUNT);
const latestGuides = guideArticles.slice(0, 3);

// Live data stats for the "decoded by data" hero strip.
const reviewCount = reviews.length;
const productsAnalyzed = articles.reduce((n, a) => n + a.products.length, 0);
const reviewsCrunched = articles.reduce(
  (n, a) => n + a.products.reduce((m, p) => m + (p.reviewCount ?? 0), 0),
  0
);
const fmt = (n: number) =>
  n >= 1_000_000 ? `${(n / 1_000_000).toFixed(1)}M`
  : n >= 1_000 ? `${(n / 1_000).toFixed(n >= 10_000 ? 0 : 1)}k`
  : `${n}`;

const stats = [
  { value: fmt(reviewsCrunched), label: 'reviews analyzed' },
  { value: `${productsAnalyzed}`, label: 'products scored' },
  { value: `${reviewCount}`, label: 'buying guides' },
  { value: '0', label: 'sponsored picks' },
];

// Home <title> — brand + keyword-rich slogan (SEOHead won't re-append the name).
const homeTitle = `${siteConfig.name} — Data-Driven Painting & Home Improvement Reviews`;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? `https://${siteConfig.domain}`;
const sameAs = Object.values(siteConfig.social ?? {}).filter(Boolean);
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteConfig.name,
  url: `${siteUrl}/`,
  logo: `${siteUrl}/favicon.svg`,
  description: siteConfig.description,
  ...(sameAs.length ? { sameAs } : {}),
};
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteConfig.name,
  url: `${siteUrl}/`,
  description: siteConfig.description,
};
---
<BaseLayout title={homeTitle} description={siteConfig.description}>
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <!-- Hero -->
  <section class="hero blueprint-grid">
    <div class="container hero-inner">
      <p class="hero-eyebrow"><span class="slash">//</span> data-verified picks</p>
      <h1 class="hero-title">{siteConfig.tagline}</h1>
      <p class="hero-sub">
        We crunch thousands of verified buyer reviews, real-world ratings and price
        trends across every category — then score each product 0&ndash;100 with the
        <strong>Kirk Score</strong>. No fluff, no sponsorships, just the gear the data backs.
      </p>

      {productsAnalyzed > 0 && (
        <div class="hero-stats" role="list" aria-label="Site stats">
          {stats.map((s) => (
            <div class="stat" role="listitem">
              <span class="stat-value">{s.value}</span>
              <span class="stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      )}

      <nav class="category-pills" aria-label="Browse by category">
        {siteConfig.categories.map((cat) => (
          <a href={`/${cat.slug}/`} class="pill">{cat.label}</a>
        ))}
      </nav>
    </div>
  </section>

  <!-- Featured review -->
  {featured && (
    <section class="container section-gap">
      <h2 class="section-label"><span class="slash">//</span> featured review</h2>
      <ArticleCard article={featured} featured />
    </section>
  )}

  <!-- Latest reviews -->
  {rest.length > 0 && (
    <section class="container section-gap">
      <h2 class="section-label"><span class="slash">//</span> latest reviews</h2>
      <div class="articles-grid">
        {rest.map((article) => (
          <ArticleCard article={article} />
        ))}
      </div>
    </section>
  )}

  <!-- Guides (informational) -->
  {latestGuides.length > 0 && (
    <section class="container section-gap">
      <div class="section-head">
        <h2 class="section-label"><span class="slash">//</span> guides &amp; how-tos</h2>
        <a href="/guides/" class="section-more">All guides →</a>
      </div>
      <div class="articles-grid">
        {latestGuides.map((article) => (
          <ArticleCard article={article} />
        ))}
      </div>
    </section>
  )}

  <!-- How we score (trust / methodology bar) -->
  <section class="method-bar">
    <div class="container">
      <h2 class="method-title">How a pick earns its Kirk Score</h2>
      <ol class="method-steps" role="list">
        <li><span class="step-no">01</span><div><strong>Gather the data</strong><p>Verified buyer ratings, review counts and price history for every product in a category.</p></div></li>
        <li><span class="step-no">02</span><div><strong>Score 0&ndash;100</strong><p>Star rating weighted by review volume — popularity can't fake quality.</p></div></li>
        <li><span class="step-no">03</span><div><strong>Rank &amp; explain</strong><p>Best overall, best value, best for pros — with the trade-offs spelled out.</p></div></li>
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    background: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-border);
    padding: 4.5rem 0 3.25rem;
  }

  .hero-inner { max-width: 760px; }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent-ink);
    margin-bottom: 1rem;
  }

  .slash { opacity: 0.75; }

  .hero-title {
    font-size: clamp(2.1rem, 5.2vw, 3.2rem);
    font-weight: 700;
    line-height: 1.08;
    color: var(--color-primary);
    margin-bottom: 1.1rem;
    letter-spacing: -0.025em;
  }

  .hero-sub {
    font-size: 1.08rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin-bottom: 2rem;
    line-height: 1.65;
  }

  .hero-sub strong { color: var(--color-primary); font-weight: 600; }

  /* ── Stats strip ── */
  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    margin-bottom: 2.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: rgba(255,255,255,0.7);
    overflow: hidden;
    width: fit-content;
    max-width: 100%;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.85rem 1.5rem;
    border-right: 1px solid var(--color-border);
  }

  .stat:last-child { border-right: none; }

  .stat-value {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  /* ── Category pills ── */
  .category-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .pill {
    display: inline-block;
    padding: 0.4em 0.95em;
    border: 1px solid var(--color-border);
    border-radius: 2em;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-text);
    background: #fff;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  .pill:hover {
    border-color: var(--color-accent);
    background: var(--color-primary);
    color: #fff;
    text-decoration: none;
  }

  /* ── Content sections ── */
  .section-gap {
    padding-top: 3rem;
    padding-bottom: 1rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .section-label .slash { color: var(--color-accent-ink); }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .section-head .section-label { margin-bottom: 0; }

  .section-more {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-accent-ink);
    white-space: nowrap;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* ── Methodology bar ── */
  .method-bar {
    background: var(--color-bg-dark);
    color: rgba(255,255,255,0.85);
    margin-top: 4rem;
    padding: 3rem 0;
    background-image: var(--blueprint-grid);
    background-size: 28px 28px;
  }

  .method-title {
    color: #fff;
    font-size: 1.4rem;
    margin-bottom: 1.75rem;
  }

  .method-steps {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .method-steps li {
    display: flex;
    gap: 0.9rem;
    align-items: flex-start;
  }

  .step-no {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-accent);
    border: 1px solid rgba(30,159,216,0.4);
    border-radius: var(--radius-sm);
    padding: 0.15rem 0.4rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .method-steps strong {
    display: block;
    color: #fff;
    font-weight: 600;
    margin-bottom: 0.2rem;
    font-family: var(--font-heading);
  }

  .method-steps p {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.55;
  }

  @media (max-width: 900px) {
    .articles-grid { grid-template-columns: repeat(2, 1fr); }
    .method-steps { grid-template-columns: 1fr; gap: 1.25rem; }
  }

  @media (max-width: 560px) {
    .articles-grid { grid-template-columns: 1fr; }
    .hero { padding: 3rem 0 2.25rem; }
    .stat { flex: 1 1 50%; border-bottom: 1px solid var(--color-border); }
    .stat:nth-child(2) { border-right: none; }
  }
</style>
